rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /habits/{habitId} {
      // Read: must own the habit
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Create: userId in the new doc must match the logged-in user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Update/delete: must own the existing habit
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /habitLogs/{logId} {
      // Read: must own the log
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Create: userId in the new log must match the logged-in user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Update/delete: must own the existing log
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}